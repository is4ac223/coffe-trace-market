---
import Layout from '../layouts/Layout.astro';
import BreadcrumbRadio from '../components/BreadcrumbRadio.astro';
import PurchasePanel from '../components/product-detail/PurchasePanel.astro';
import ProductionChronology from '../components/product-detail/ProductionChronology.astro';

import { 
    getI18n,
    resolveLocale,
    readConsent 
} from '../lib/i18n';

const consent = readConsent(Astro.cookies);
const locale = resolveLocale(Astro.cookies, Astro.url, Astro.request, consent);
const { m } = getI18n(locale);

// Capturar parámetros URL dinámicos enviados desde el index
const title = Astro.url.searchParams.get('title') || 'Café Tostado Origen Loja - Altura';
const description = Astro.url.searchParams.get('description') || 'Café de especialidad con notas a chocolate y acidez cítrica.';
const price = Astro.url.searchParams.get('price') || '$15.50';
const stock = Astro.url.searchParams.get('stock') || '45 u.';

const checkoutSteps = [
  { label: m.checkoutSteps.detail, url: '/product-detail' },

];
---

<Layout locale={locale} title={`${title} - DApp HA Commerce`} description={description}>
  <main class="detail-container">
    <BreadcrumbRadio steps={checkoutSteps} currentStep={1} />

    <div class="main-grid">
      <section class="info-section">
        {/* <div class="badge-origin">✓ Certified Origin</div> */}
        <h1 class="product-title">{title}</h1>
        <p class="product-description">{description}</p>
        
        <div class="product-media-placeholder">
          <span>[ Vista de Trazabilidad del Lote ]</span>
        </div>

        <ProductionChronology />
      </section>

      <aside>
        <PurchasePanel price={price} stock={stock} />
      </aside>
    </div>
  </main>
</Layout>

<style is:global>
  body {
    font-family: 'Manrope', sans-serif !important;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.9), rgba(244, 241, 235, 0.96) 40%),
      linear-gradient(180deg, #f7f3ee 0%, #f1eee8 100%) !important;
  }
</style>

<style>
  .detail-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
    
    animation: fadeIn 0.4s ease-out;
  }
  .main-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 40px;
    align-items: start;
  }
  .badge-origin {
    display: inline-block;
    background: #e6f4ea;
    color: #137333;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 20px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .product-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #111827;
    line-height: 1.1;
    margin-bottom: 8px;
  }
  .product-description {
    font-size: 1.1rem;
    color: #4b5563;
    margin-bottom: 24px;
    max-width: 600px;
  }
  .product-media-placeholder {
    width: 100%;
    height: 350px;
    background: #eaeaea;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #71717a;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .main-grid {
      grid-template-columns: 1fr;
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>