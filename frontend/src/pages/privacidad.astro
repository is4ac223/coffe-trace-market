---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import CookieConsent from '../components/privacy/CookieConsent.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import {
	allowsCategory,
	hasConsentDecision,
} from '../lib/privacy/consent';
import {
	getI18n,
	isLocale,
	persistLocaleCookie,
	readConsent,
	resolveLocale,
} from '../lib/i18n';

const queryLang = Astro.url.searchParams.get('lang');
if (isLocale(queryLang)) {
	const consent = readConsent(Astro.cookies);
	if (consent && allowsCategory(consent, 'functional')) {
		persistLocaleCookie(Astro.cookies, queryLang);
	}
	return Astro.redirect(Astro.url.pathname);
}

const consent = readConsent(Astro.cookies);
const locale = resolveLocale(Astro.cookies, Astro.url, Astro.request, consent);
const { m, pm } = getI18n(locale);
---

<Layout locale={locale} title={pm.legal.pageTitle} description={pm.legal.pageDescription}>
	<main class="legal-page">
		<header class="legal-topbar">
			<a href="/" class="back-link">← {pm.legal.backHome}</a>
			<LanguageSwitcher locale={locale} label={m.lang.switcherLabel} />
		</header>

		<article class="legal-card">
			<p class="eyebrow">LOPDP · Ecuador</p>
			<h1>{pm.legal.pageTitle}</h1>
			<p class="updated">{pm.legal.lastUpdated}</p>

			{pm.legal.sections.map((section) => (
				<section>
					<h2>{section.title}</h2>
					{section.paragraphs.map((paragraph) => (
						<p>{paragraph}</p>
					))}
				</section>
			))}

			<section>
				<h2>{pm.cookies.modalTitle}</h2>
				<p>{pm.cookies.modalBody}</p>
				<button type="button" class="manage-btn" id="open-cookie-settings">
					{pm.cookies.manageLink}
				</button>
			</section>
		</article>
	</main>

	<CookieConsent locale={locale} pm={pm} hasConsent={hasConsentDecision(consent)} />
</Layout>

<script>
	document.getElementById('open-cookie-settings')?.addEventListener('click', () => {
		document.dispatchEvent(new CustomEvent('origin:open-cookie-settings'));
	});
</script>

<style>
	.legal-page {
		width: min(860px, calc(100% - 32px));
		margin: 0 auto;
		padding: 24px 0 80px;
		font-family: 'Manrope', sans-serif;
		color: #121212;
	}

	.legal-topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 12px;
		margin-bottom: 18px;
	}

	.back-link {
		color: #166534;
		font-weight: 700;
		text-decoration: none;
	}

	.legal-card {
		background: rgba(255, 255, 255, 0.86);
		border: 1px solid rgba(18, 18, 18, 0.08);
		border-radius: 24px;
		padding: 32px;
		box-shadow: 0 18px 40px rgba(18, 18, 18, 0.08);
	}

	.eyebrow {
		display: inline-flex;
		padding: 6px 10px;
		border-radius: 999px;
		background: rgba(22, 101, 52, 0.12);
		color: #166534;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		line-height: 1.1;
		margin: 14px 0 8px;
	}

	.updated {
		color: rgba(18, 18, 18, 0.56);
		margin: 0 0 24px;
	}

	section {
		margin-top: 22px;
	}

	h2 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.1rem;
		margin: 0 0 8px;
	}

	p {
		margin: 0 0 10px;
		line-height: 1.65;
		color: rgba(18, 18, 18, 0.78);
	}

	.manage-btn {
		margin-top: 8px;
		border: 0;
		border-radius: 10px;
		padding: 10px 14px;
		background: #111;
		color: #fff;
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		cursor: pointer;
	}
</style>
