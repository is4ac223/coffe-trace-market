---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Panel de Control">
  <div class="dashboard-header">
    <h1 id="welcome-text">Hola, Productor</h1>
    <p>Resumen general de tu actividad en la plataforma.</p>
  </div>

  <div class="kpi-grid">
    <div class="kpi-card from-ruby-500">
      <h3>Total Productos</h3>
      <div class="value" id="kpi-productos">24</div>
      <p id="kpi-productos-meta">Cargando desde la base de datos...</p>
    </div>
    <div class="kpi-card from-slate-700">
      <h3>Ventas (POS + Web)</h3>
      <div class="value">$ 4,250.00</div>
      <p>12 transacciones recientes</p>
    </div>
    <div class="kpi-card from-amber-900">
      <h3>Lotes Registrados</h3>
      <div class="value" id="kpi-lotes">8</div>
      <p id="kpi-lotes-meta">Cargando desde la base de datos...</p>
    </div>
  </div>
</DashboardLayout>

<style>
  .dashboard-header { margin-bottom: 32px; }
  .dashboard-header h1 { font-family: 'Space Grotesk', sans-serif; font-size: 2.5rem; margin: 0 0 8px 0; }
  .dashboard-header p { color: #6b7280; font-size: 1.1rem; margin: 0; }

  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  
  .kpi-card {
    padding: 24px;
    border-radius: 20px;
    color: white;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  }
  .kpi-card h3 { margin: 0 0 16px 0; font-size: 1rem; font-weight: 600; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;}
  .kpi-card .value { font-family: 'Space Grotesk', sans-serif; font-size: 2.8rem; font-weight: 700; margin-bottom: 8px;}
  .kpi-card p { margin: 0; font-size: 0.85rem; opacity: 0.8; }

  /* Se reutiliza los gradientes del Landing */
  .from-ruby-500 { background: linear-gradient(135deg, #2b5c45, #161f1b); }
  .from-slate-700 { background: linear-gradient(135deg, #12222f, #0f1112); }
  .from-amber-900 { background: linear-gradient(135deg, #3b2418, #131516); }
</style>

<script>
  import { fetchLotes } from '../../lib/api/lotes';
  import { fetchProductos } from '../../lib/api/productos';

  // Personalizar el saludo
  document.addEventListener('DOMContentLoaded', async () => {
    const role = localStorage.getItem('user_role') || 'Usuario';
    const name = localStorage.getItem('user_name') || '';
    const formatearRol = role.charAt(0).toUpperCase() + role.slice(1);

    const welcome = document.getElementById('welcome-text');
    if (welcome) {
      if (name) {
        welcome.textContent = `¡Hola, ${name}! (${formatearRol})`;
      } else {
        welcome.textContent = `Hola, ${formatearRol}`;
      }
    }

    try {
      const [productos, lotes] = await Promise.all([fetchProductos(), fetchLotes()]);

      const productosValue = document.getElementById('kpi-productos');
      if (productosValue) productosValue.textContent = String(productos.length);

      const lotesValue = document.getElementById('kpi-lotes');
      if (lotesValue) lotesValue.textContent = String(lotes.length);

      const productosMeta = document.getElementById('kpi-productos-meta');
      if (productosMeta) productosMeta.textContent = 'Productos cargados desde la base de datos local';

      const lotesMeta = document.getElementById('kpi-lotes-meta');
      if (lotesMeta) lotesMeta.textContent = 'Lotes cargados desde la base de datos local';
    } catch {
      const productosMeta = document.getElementById('kpi-productos-meta');
      if (productosMeta) productosMeta.textContent = 'No fue posible cargar el conteo en este momento';

      const lotesMeta = document.getElementById('kpi-lotes-meta');
      if (lotesMeta) lotesMeta.textContent = 'No fue posible cargar el conteo en este momento';
    }
  });
</script>