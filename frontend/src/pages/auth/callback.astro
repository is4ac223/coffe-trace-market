---
import Layout from '../../layouts/Layout.astro';
import { resolveLocale } from '../../lib/i18n';

const locale = resolveLocale(Astro.cookies, Astro.url, Astro.request, null);
---

<Layout locale={locale} title="Sincronizando cuenta...">
    <main class="callback-container">
        <div class="loader"></div>
        <h2>Sincronizando tu cuenta con CoffeeTrace Market...</h2>
        <p id="status-text">Por favor, espera un momento.</p>
    </main>
</Layout>

<style>
    .callback-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        text-align: center;
        font-family: 'Space Grotesk', sans-serif;
    }
    .loader {
        width: 48px;
        height: 48px;
        border: 4px solid #111;
        border-bottom-color: transparent;
        border-radius: 50%;
        animation: rotation 1s linear infinite;
        margin-bottom: 20px;
    }
    @keyframes rotation {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

<script>
    import { supabase } from '../../lib/supabase';

    const API_URL = import.meta.env.PUBLIC_API_BASE_URL;
    const statusText = document.getElementById('status-text');

    let syncing = false;

    async function syncWithBackend(accessToken: string) {
        if (syncing) return; // evita llamadas duplicadas
        syncing = true;

        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 10000); // 10s timeout

        try {
            const response = await fetch(`${API_URL}/api/auth/google/sync`, {
                method: 'GET',
                headers: {
                    'Authorization': `Bearer ${accessToken}`,
                    'Content-Type': 'application/json'
                },
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) {
                throw new Error(`Fallo la sincronización con el backend (status ${response.status}).`);
            }

            const data = await response.json();

            if (data?.perfil_pendiente) {
                if (statusText) {
                    statusText.textContent = 'Cuenta creada exitosamente, redirigiendo a creación de perfil';
                }
                window.location.href = '/auth/new-profile';
            } else {
                window.location.href = '/';
            }

        } catch (error) {
            console.error("Error de sincronización:", error);
            if (statusText) {
                statusText.textContent = 'Hubo un problema al sincronizar tu cuenta. Redirigiendo...';
            }
            await supabase.auth.signOut();
            setTimeout(() => {
                window.location.href = '/auth/login?error=sync_failed';
            }, 1500);
        } finally {
            syncing = false;
        }
    }

    async function init() {
        // 1. Revisar si ya hay sesión disponible de inmediato
        const { data: { session } } = await supabase.auth.getSession();

        if (session) {
            syncWithBackend(session.access_token);
            return;
        }

        // 2. Si no, esperar al evento (flujo OAuth con hash en la URL)
        const { data: { subscription } } = supabase.auth.onAuthStateChange((event, newSession) => {
            if (event === 'SIGNED_IN' && newSession) {
                subscription.unsubscribe(); // ya no necesitamos seguir escuchando
                syncWithBackend(newSession.access_token);
            }
        });

        // 3. Si después de un tiempo razonable no llegó nada, mandamos a login
        setTimeout(() => {
            if (!syncing) {
                subscription.unsubscribe();
                window.location.href = '/auth/login';
            }
        }, 8000);
    }

    init();
</script>