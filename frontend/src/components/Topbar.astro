---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ApiStatus from './ApiStatus.astro';
import { getCatalogData } from '../lib/catalog';
import { Icon } from 'astro-icon/components';

interface Props {
  locale: string;
  m: any;
  apiOnline: boolean;
  apiError: any;
}

const { locale, m, apiOnline, apiError} = Astro.props;
---

<header class="topbar">
  <div class="brand">
    <span class="menu"><Icon name="coffee" class="icon"/></span>
    <span>CoffeeTrace Market</span>
  </div>
  <nav>
    <a href="/#market">{m.nav.market}</a>
    <a href="/#auctions">{m.nav.auctions}</a>
    <a href="/#wallet">{m.nav.wallet}</a>
    <a href="/#profile">{m.nav.profile}</a>
    <button type="button" class="sample-link" data-open-sample>{m.nav.sampleRequest ?? 'Solicitar muestra'}</button>
  </nav>
  <div class="topbar-actions">
    <LanguageSwitcher locale={locale} label={m.lang.switcherLabel} />
    <a href="/auth/login" class="login" data-login-link>{m.login.name}</a>
    <ApiStatus online={apiOnline && !apiError} m={m} />
  </div>
</header>

<div class="sample-modal" data-sample-modal hidden aria-hidden="true">
  <div class="sample-backdrop" data-close-sample></div>
  <section class="sample-card" role="dialog" aria-modal="true" aria-labelledby="sample-title">
    <button type="button" class="sample-close" aria-label="Cerrar" data-close-sample>✕</button>
    <p class="sample-kicker">Solicitud Comercial</p>
    <h2 id="sample-title">Solicitar muestra</h2>
    <p class="sample-copy">Completa los datos y te contactaremos para coordinar el envio.</p>

    <form class="sample-form" data-sample-form>
      <label>
        Empresa
        <input type="text" name="empresa" placeholder="Nombre de la empresa" required />
      </label>
      <label>
        Correo
        <input type="email" name="correo" placeholder="compras@empresa.com" required />
      </label>
      <label>
        Direccion
        <input type="text" name="direccion" placeholder="Calle, ciudad, pais" required />
      </label>
      <label>
        Pedido
        <textarea name="pedido" rows="4" placeholder="Detalla origen, volumen y requerimientos" required></textarea>
      </label>
      <div class="sample-actions">
        <button type="button" class="sample-secondary" data-close-sample>Cancelar</button>
        <button type="submit" class="sample-primary">Enviar solicitud</button>
      </div>
    </form>
  </section>
</div>

<script>
  import { supabase } from '../lib/supabase';
  const loginLink = document.querySelector('[data-login-link]');
  const modal = document.querySelector('[data-sample-modal]');
  const openModalBtn = document.querySelector('[data-open-sample]');
  const closeModalEls = document.querySelectorAll('[data-close-sample]');
  const sampleForm = document.querySelector('[data-sample-form]');

  const openSampleModal = () => {
    if (!(modal instanceof HTMLElement)) return;
    modal.hidden = false;
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const closeSampleModal = () => {
    if (!(modal instanceof HTMLElement)) return;
    modal.hidden = true;
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  // Fuerza estado inicial cerrado incluso si el atributo hidden se pierde por estilos/global reset.
  closeSampleModal();

  openModalBtn?.addEventListener('click', openSampleModal);
  closeModalEls.forEach((el) => {
    el.addEventListener('click', (event) => {
      event.preventDefault();
      closeSampleModal();
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeSampleModal();
  });

  sampleForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    closeSampleModal();
  });

  const updateLoginVisibility = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      loginLink?.remove();
    }
  };

  updateLoginVisibility();

  supabase.auth.onAuthStateChange((_event, session) => {
    if (session) {
      loginLink?.remove();
    }
  });
</script>

<style>
  .topbar {
    display: flex;
    position: sticky;
    top: 16px;
    z-index: 100;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(18, 18, 18, 0.08);
    box-shadow: 0 14px 35px rgba(18, 18, 18, 0.08);
    border-radius: 24px;
    font-family: 'Manrope', sans-serif;
  }

  .brand, .topbar-actions, nav {
    display: flex;
  }

  .topbar-actions {
    align-items: center;
    gap: 12px;
  }

  .brand {
    align-items: center;
    gap: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    color: #121212;
  }

  .menu, .icon-badge {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #111;
    color: white;
    font-size: 0.9rem;
  }

  nav {
    gap: 28px;
    font-size: 0.92rem;
  }

  nav a {
    color: #121212;
    text-decoration: none;
    opacity: 0.82;
  }

  nav a:hover,
  .sample-link:hover {
    opacity: 1;
  }

  .sample-link {
    border: 0;
    background: none;
    color: #121212;
    opacity: 0.82;
    font: inherit;
    cursor: pointer;
    padding: 0;
  }

  .login {
    display: inline-block;
    text-align: center;
    color: white;
    text-decoration: none;
    background-color: #121212;
		padding: 8px 14px 8px 14px;
		font-size: 0.78rem;
    border-radius: 999px;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }

  .login:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--color-on-surface);
  }

  .sample-modal {
    position: fixed;
    inset: 0;
    z-index: 150;
    display: grid;
    place-items: center;
    padding: 16px;
  }

  .sample-modal[hidden] {
    display: none !important;
  }

  .sample-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 12, 10, 0.55);
    backdrop-filter: blur(2px);
  }

  .sample-card {
    position: relative;
    width: min(560px, 100%);
    background: #fefbf4;
    border: 1px solid rgba(18, 18, 18, 0.12);
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 22px 50px rgba(0, 0, 0, 0.25);
  }

  .sample-close {
    position: absolute;
    top: 14px;
    right: 14px;
    border: 0;
    background: #111;
    color: #fff;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    cursor: pointer;
  }

  .sample-kicker {
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    color: #2f6b52;
    font-weight: 800;
  }

  .sample-card h2 {
    margin: 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.6rem;
  }

  .sample-copy {
    margin: 8px 0 18px;
    color: #5b5d5b;
    font-size: 0.92rem;
  }

  .sample-form {
    display: grid;
    gap: 12px;
  }

  .sample-form label {
    display: grid;
    gap: 6px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #3b3e3c;
  }

  .sample-form input,
  .sample-form textarea {
    border: 1px solid #d7dbd6;
    border-radius: 10px;
    padding: 12px;
    font: inherit;
    background: #fff;
  }

  .sample-form textarea {
    resize: vertical;
    min-height: 96px;
  }

  .sample-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 4px;
  }

  .sample-secondary,
  .sample-primary {
    border: 0;
    border-radius: 10px;
    padding: 10px 14px;
    font-weight: 700;
    cursor: pointer;
  }

  .sample-secondary {
    background: #eceee9;
    color: #1c1f1d;
  }

  .sample-primary {
    background: #1f3c31;
    color: #fff;
  }

  @media (max-width: 980px) {
    nav {
      display: none;
    }
    .topbar-actions {
      flex-wrap: wrap;
      justify-content: flex-end;
    }
  }

  @media (max-width: 720px) {
    .topbar {
      border-radius: 20px;
    }

    .sample-card {
      padding: 20px;
      border-radius: 16px;
    }

    .sample-actions {
      flex-direction: column-reverse;
    }
  }
</style>