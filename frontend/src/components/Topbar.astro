---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ApiStatus from './ApiStatus.astro';
import { getCatalogData } from '../lib/catalog';
import { Icon } from 'astro-icon/components';

interface Props {
  locale: string;
  m: any;
  apiOnline: boolean;
  apiError: any;
}

const { locale, m, apiOnline, apiError} = Astro.props;
---

<header class="topbar">
  <div class="brand">
    <span class="menu"><Icon name="coffee" class="icon"/></span>
    <span>CoffeeTrace Market</span>
  </div>
  <nav>
    <a href="/#market">{m.nav.market}</a>
    <a href="/#auctions">{m.nav.auctions}</a>
    <a href="/#wallet">{m.nav.wallet}</a>
    <a href="/#profile">{m.nav.profile}</a>
  </nav>
  <div class="topbar-actions">
    <LanguageSwitcher locale={locale} label={m.lang.switcherLabel} />
    <a href="/auth/login" class="login" data-login-link>{m.login.name}</a>
    <ApiStatus online={apiOnline && !apiError} m={m} />
  </div>
</header>

<script>
  import { supabase } from '../lib/supabase';
  const loginLink = document.querySelector('[data-login-link]');

  const updateLoginVisibility = async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      loginLink?.remove();
    }
  };

  updateLoginVisibility();

  supabase.auth.onAuthStateChange((_event, session) => {
    if (session) {
      loginLink?.remove();
    }
  });
</script>

<style>
  .topbar {
    display: flex;
    position: sticky;
    top: 16px;
    z-index: 100;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(18, 18, 18, 0.08);
    box-shadow: 0 14px 35px rgba(18, 18, 18, 0.08);
    border-radius: 24px;
    font-family: 'Manrope', sans-serif;
  }

  .brand, .topbar-actions, nav {
    display: flex;
  }

  .topbar-actions {
    align-items: center;
    gap: 12px;
  }

  .brand {
    align-items: center;
    gap: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    color: #121212;
  }

  .menu, .icon-badge {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #111;
    color: white;
    font-size: 0.9rem;
  }

  nav {
    gap: 28px;
    font-size: 0.92rem;
  }

  nav a {
    color: #121212;
    text-decoration: none;
    opacity: 0.82;
  }

  nav a:hover {
    opacity: 1;
  }

  .login {
    display: inline-block;
    text-align: center;
    color: white;
    text-decoration: none;
    background-color: #121212;
		padding: 8px 14px 8px 14px;
		font-size: 0.78rem;
    border-radius: 999px;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }

  .login:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--color-on-surface);
  }

  @media (max-width: 980px) {
    nav {
      display: none;
    }
    .topbar-actions {
      flex-wrap: wrap;
      justify-content: flex-end;
    }
  }

  @media (max-width: 720px) {
    .topbar {
      border-radius: 20px;
    }
  }
</style>