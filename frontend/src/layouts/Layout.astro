---
import * as i18nModule from '../lib/i18n';
import type { Locale } from '../lib/i18n';
import type { PrivacyMessages } from '../lib/i18n/privacy-messages';
import CookieConsent from '../components/privacy/CookieConsent.astro';
import { hasConsentDecision } from '../lib/privacy/consent';
import Topbar from '../components/Topbar.astro';

import '../styles/globals.css';

interface Props {
	locale: Locale;
	title: string;
	description: string;
	pm?: PrivacyMessages;
	consent?: ReturnType<typeof import('../lib/privacy/consent').parseConsentCookie>;
}

const { locale, title, description, pm, consent = null } = Astro.props;
const { m } = i18nModule.getI18n(locale);
// PARA PRUEBA, CAMBIAR
const apiOnline = true; 
const apiError = null;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
		/>
	</head>
	<body>
		<div class="page-shell">
			{/* Header global*/}
			<Topbar locale={locale} m={m} apiOnline={apiOnline} apiError={apiError} />

			<slot />
			{pm && <CookieConsent locale={locale} pm={pm} hasConsent={hasConsentDecision(consent)} />}
		</div>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: #f4f1eb;
	}
</style>
