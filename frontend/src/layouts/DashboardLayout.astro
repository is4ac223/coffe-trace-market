---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>{title} - CoffeeTrace Market</title>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap');
    
    body {
      margin: 0;
      font-family: 'Manrope', sans-serif;
      background-color: #f7f5f0;
      color: #121212;
      display: flex;
      height: 100vh;
      overflow: hidden;
    }
    
    /* --- SIDEBAR --- */
    .sidebar {
      width: 260px;
      background: rgba(255, 255, 255, 0.72);
      backdrop-filter: blur(18px);
      border-right: 1px solid rgba(18, 18, 18, 0.08);
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
      z-index: 50;
    }
    .sidebar.closed { transform: translateX(-100%); position: absolute; }
    
    .brand {
      padding: 24px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 800;
      font-size: 1.2rem;
      letter-spacing: 0.05em;
      border-bottom: 1px solid rgba(18, 18, 18, 0.08);
    }
    
    .user-profile {
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 1px solid rgba(18, 18, 18, 0.08);
    }
    .user-avatar {
      width: 45px; height: 45px; border-radius: 50%; background: #e5e7eb; object-fit: cover;
    }
    .user-info h4 { margin: 0; font-size: 0.95rem; }
    .user-info p { margin: 0; font-size: 0.75rem; color: #6b7280; text-transform: uppercase; font-weight: 700; }
    
    .nav-links { flex: 1; padding: 20px 0; display: flex; flex-direction: column; gap: 8px; }
    .nav-links a {
      padding: 12px 24px;
      text-decoration: none;
      color: #4b5563;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: all 0.2s;
    }
    .nav-links a:hover { background: rgba(18, 18, 18, 0.04); color: #111; }
    .nav-links a.active { background: #111; color: #fff; margin: 0 12px; border-radius: 12px; }
    
    .logout-btn {
      padding: 20px 24px;
      border-top: 1px solid rgba(18, 18, 18, 0.08);
      color: #b91c1c;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .logout-btn:hover { background: rgba(185, 28, 28, 0.05); }

    /* --- MAIN CONTENT & TOPBAR --- */
    .main-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    
    .topbar {
      height: 70px;
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(18, 18, 18, 0.08);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
    }
    
    .topbar-left { display: flex; align-items: center; gap: 16px; }
    .menu-toggle {
      background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #111;
    }
    
    .topbar-right { display: flex; align-items: center; gap: 16px; }
    .icon-btn {
      width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(18,18,18,0.1);
      background: #fff; display: grid; place-items: center; cursor: pointer; transition: 0.2s;
    }
    .icon-btn:hover { background: #f3f4f6; }
    
    .lang-switcher {
      padding: 8px 16px; border: 1px solid rgba(18,18,18,0.1); border-radius: 999px;
      background: #fff; font-size: 0.8rem; font-weight: 700; cursor: pointer;
    }

    .content-area {
      flex: 1;
      padding: 32px;
      overflow-y: auto;
    }
  </style>
</head>
<body>

  <aside class="sidebar" id="sidebar">
    <div class="brand">⌂ CoffeeTrace Market</div>
    
    <div class="user-profile">
      <img src="" alt="Avatar" class="user-avatar" id="ui-avatar" />
      <div class="user-info">
        <h4 id="ui-name">Cargando...</h4>
        <p id="ui-role">Cargando...</p>
      </div>
    </div>

    <nav class="nav-links">
      <a href="/dashboard" id="link-dashboard">📊 Dashboard</a>
      <a href="/dashboard/lotes" id="link-lotes">📦 Lotes</a>
      <a href="/dashboard/productos" id="link-productos">☕ Productos</a>
    </nav>

    <div class="logout-btn" id="btn-logout">
      🚪 Cerrar Sesión
    </div>
  </aside>

  <div class="main-wrapper">
    <header class="topbar">
      <div class="topbar-left">
        <button class="menu-toggle" id="btn-menu">☰</button>
      </div>
      <div class="topbar-right">
        <button class="lang-switcher">Español 🌐</button>
        <div class="icon-btn">🔔</div>
        <div class="icon-btn">⚙️</div>
      </div>
    </header>

    <main class="content-area">
      <slot /> </main>
  </div>

  <script>
    import { supabase } from '../lib/supabase';

    // 1. Manejo del menú hamburguesa
    document.getElementById('btn-menu')?.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.toggle('closed');
    });

    // 2. Marcar menú activo
    const path = window.location.pathname;
    if (path.includes('lotes')) document.getElementById('link-lotes')?.classList.add('active');
    else if (path.includes('productos')) document.getElementById('link-productos')?.classList.add('active');
    else document.getElementById('link-dashboard')?.classList.add('active');

    // 3. Cargar datos del usuario desde Supabase y LocalStorage
    document.addEventListener('DOMContentLoaded', async () => {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/login';
        return;
      }
      
      const meta = session.user.user_metadata;
      const role = (localStorage.getItem('user_role') || 'Usuario').trim();
      const roleDisplay = role === 'Usuario' ? role : role.charAt(0).toUpperCase() + role.slice(1).toLowerCase();

      const avatarEl = document.getElementById('ui-avatar') as HTMLImageElement;
      if (avatarEl) avatarEl.src = meta.avatar_url || 'https://api.dicebear.com/7.x/avataaars/svg?seed=Origin';
      
      const nameEl = document.getElementById('ui-name');
      if (nameEl) nameEl.textContent = meta.full_name || session.user.email;
      
      const roleEl = document.getElementById('ui-role');
      if (roleEl) roleEl.textContent = roleDisplay;
    });

    // 4. Cerrar sesión
    document.getElementById('btn-logout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      localStorage.removeItem('user_role');
      window.location.href = '/';
    });
  </script>
</body>
</html>